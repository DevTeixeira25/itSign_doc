# ─── ITSign Environment Variables (Production) ──────────────────────

# Firebase (API)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"itsign-79d36",...}

# Database (PostgreSQL)
DATABASE_URL=postgres://user:pass@host:5432/itsign

# JWT secret (generate a strong random string)
JWT_SECRET=change-me-to-a-strong-random-secret

# Storage (Cloud Storage bucket or local path)
STORAGE_DIR=/tmp/itsign-storage

# App URLs (Firebase Hosting URL)
WEB_URL=https://itsign-79d36.web.app
API_URL=https://southamerica-east1-itsign-79d36.cloudfunctions.net/api

# Gov.br OAuth2 (staging)
GOVBR_MOCK=false
GOVBR_CLIENT_ID=your-govbr-client-id
GOVBR_CLIENT_SECRET=your-govbr-client-secret
GOVBR_PRODUCTION=false
