# ── Gov.br Integration ────────────────────────────────────────
# Para integrar com o Gov.br de verdade, siga os passos:
#
# 1. Acesse: https://acesso.gov.br/roteiro-tecnico/solicitacaocredencialprocesso.html
# 2. Solicite credenciais de STAGING (homologação) primeiro
# 3. Configure o redirect_uri como: http://localhost:3001/v1/govbr/callback (dev)
#    ou https://seu-dominio.com.br/v1/govbr/callback (produção)
# 4. Preencha os valores abaixo com suas credenciais reais
# 5. Remova GOVBR_MOCK=true quando estiver pronto para testar com dados reais

# Mock mode: usa dados falsos para desenvolvimento sem credenciais Gov.br
GOVBR_MOCK=true

# Credenciais OAuth2 do Gov.br (obtenha no portal de integração)
GOVBR_CLIENT_ID=
GOVBR_CLIENT_SECRET=

# Use "true" para ambiente de produção (sso.acesso.gov.br)
# Deixe vazio ou "false" para staging (sso.staging.acesso.gov.br)
GOVBR_PRODUCTION=false

# ── Firebase ──────────────────────────────────────────────────
# Configure o arquivo de service account do Firebase Admin SDK
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ── Database ──────────────────────────────────────────────────
# Se não configurado, a API usa armazenamento em memória
# DATABASE_URL=postgresql://user:password@localhost:5432/itsign
