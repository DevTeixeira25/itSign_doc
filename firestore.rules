rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Funções auxiliares ─────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    // ─── Perfis de usuário ─────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // não permite exclusão de conta via client
    }

    // ─── Envelopes (documentos para assinatura) ────────────────
    match /envelopes/{envelopeId} {
      allow read: if isAuthenticated()
                  && (resource.data.creatorId == request.auth.uid
                      || request.auth.uid in resource.data.signerIds);
      allow create: if isEmailVerified();
      allow update: if isAuthenticated()
                    && resource.data.creatorId == request.auth.uid;
      allow delete: if isAuthenticated()
                    && resource.data.creatorId == request.auth.uid
                    && resource.data.status == 'draft';

      // Sub-coleção de assinaturas
      match /signatures/{signatureId} {
        allow read: if isAuthenticated()
                    && (get(/databases/$(database)/documents/envelopes/$(envelopeId)).data.creatorId == request.auth.uid
                        || request.auth.uid in get(/databases/$(database)/documents/envelopes/$(envelopeId)).data.signerIds);
        allow create: if isAuthenticated();
        allow update: if false;
        allow delete: if false;
      }
    }

    // ─── Audit log (somente leitura pelo dono) ─────────────────
    match /audit/{logId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow write: if false; // apenas Cloud Functions escrevem
    }

    // ─── Verificação pública de documentos ─────────────────────
    match /verifications/{code} {
      allow read: if true; // qualquer pessoa pode verificar
      allow write: if false; // apenas Cloud Functions escrevem
    }

    // ─── Bloquear tudo que não foi explicitamente permitido ────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
